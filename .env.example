# Provider: "ollama" (free/local, default) or "claude"
PROVIDER=ollama

# --- Ollama (open-source path) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
HF_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Claude path (only needed if PROVIDER=claude) ---
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
VOYAGE_MODEL=voyage-3.5

# --- API security (leave API_KEY empty to run auth-free locally) ---
# API_KEY=change-me-in-production
RATE_LIMIT_PER_MIN=60

# --- caching ---
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# --- retrieval (F16 hybrid: BM25 + dense, fused with RRF) ---
RETRIEVAL_MODE=hybrid          # "hybrid" or "dense"
RETRIEVE_FETCH_K=20            # candidates each arm fetches before fusion / rerank
RRF_K=60                       # Reciprocal Rank Fusion constant

# --- re-ranking (F17 cross-encoder; off by default) ---
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- upload (F18) ---
MAX_UPLOAD_MB=25

# --- conversation memory (F19) ---
HISTORY_MAX_TURNS=6            # recent turns kept when condensing follow-ups

# --- OCR ingestion (F20; local Tesseract, no keys) ---
OCR_ENABLED=true              # OCR images + scanned PDFs during ingest
OCR_LANG=eng                  # tesseract language pack(s), e.g. "eng+deu"
OCR_DPI=200                   # rasterization DPI for scanned PDF pages
OCR_MIN_CHARS_PER_PAGE=40     # below this avg -> a PDF is treated as scanned

# --- cleaning pipeline (F21) ---
CLEAN_ENABLED=true            # normalize + strip noise between load and split
DEDUPE_ENABLED=true           # drop near-duplicate chunks after splitting
DEDUPE_THRESHOLD=0.9          # Jaccard(shingles) >= this => duplicate
